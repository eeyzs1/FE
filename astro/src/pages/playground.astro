---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Card from '../components/Card.astro';
import Counter from '../components/Counter.tsx';
import MouseFollower from '../components/MouseFollower.tsx';
import ThemeCard from '../components/ThemeCard.astro';
---

<BaseLayout title="Astro Playground — Practice Page">
  <Nav slot="header" />
  
  <section class="section">
    <h2>🧩 Astro Components</h2>
    <div class="card-grid">
      <Card title="Astro" description="The web framework for content-driven websites" />
      <Card title="React" description="A JavaScript library for building user interfaces" />
      <Card title="TypeScript" description="Typed JavaScript at any scale" />
    </div>
  </section>

  <section class="section section-spaced">
    <h2>🎨 Theme Cards (define:vars)</h2>
    <div class="theme-grid">
      <ThemeCard themeColor="#3b82f6" />
      <ThemeCard themeColor="#10b981" />
      <ThemeCard themeColor="#f59e0b" />
    </div>
  </section>

  <section class="section section-spaced">
    <h2>⚛️ React Islands</h2>
    <p><strong>Counter</strong> (client:load — hydrates immediately):</p>
    <Counter client:load initialCount={0} />
  </section>

  <section class="section section-spaced">
    <h2>🖱️ Mouse Follower (client:load)</h2>
    <p>Move your mouse to see the follower. This component only hydrates on the client.</p>
    <MouseFollower client:load />
  </section>

  <footer slot="footer" class="footer">
    <p>Built with Astro — Practice Playground</p>
  </footer>
</BaseLayout>

<style>
  h2 {
    font-size: 1.5rem;
    margin-bottom: 16px;
  }
  .section {
    margin-bottom: 16px;
  }
  .section-spaced {
    margin-top: 48px;
  }
  p {
    color: #6b7280;
    margin-bottom: 12px;
  }
  .card-grid,
  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .theme-grid {
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  }
  .footer {
    padding: 24px;
    text-align: center;
    color: #9ca3af;
    font-size: 0.875rem;
  }
</style>
